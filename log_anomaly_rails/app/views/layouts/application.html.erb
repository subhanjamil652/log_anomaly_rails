<!DOCTYPE html>
<html lang="en">
  <head>
    <title><%= content_for(:title) || "LogAnomalyML - BGL Anomaly Detection" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>
    <%= yield :head %>

    <!-- Bootstrap 5 -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css">
    <!-- Bootstrap Icons -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <!-- Chart.js -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js"></script>

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>

    <style>
      :root {
        --bg-primary:    #0f172a;
        --bg-secondary:  #1e293b;
        --bg-card:       #1e293b;
        --bg-card-hover: #263347;
        --accent-blue:   #3b82f6;
        --accent-red:    #ef4444;
        --accent-green:  #22c55e;
        --accent-amber:  #f59e0b;
        --accent-purple: #a855f7;
        --text-primary:  #f1f5f9;
        --text-secondary:#94a3b8;
        --border-color:  #334155;
        --sidebar-width: 250px;
      }

      * { box-sizing: border-box; }
      html, body { height: 100%; margin: 0; padding: 0; }

      body {
        background: var(--bg-primary);
        color: var(--text-primary);
        font-family: 'Inter', system-ui, sans-serif;
        font-size: 0.9rem;
        display: flex;
      }

      /* -- Sidebar -- */
      .sidebar {
        width: var(--sidebar-width);
        min-height: 100vh;
        background: var(--bg-secondary);
        border-right: 1px solid var(--border-color);
        display: flex;
        flex-direction: column;
        position: fixed;
        top: 0; left: 0; bottom: 0;
        z-index: 100;
        overflow-y: auto;
      }

      .sidebar-brand {
        padding: 1.25rem 1rem;
        border-bottom: 1px solid var(--border-color);
        display: flex;
        align-items: center;
        gap: 0.6rem;
      }

      .sidebar-brand .brand-icon {
        width: 36px; height: 36px;
        background: var(--accent-blue);
        border-radius: 8px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.1rem;
      }

      .sidebar-brand .brand-name {
        font-weight: 700;
        font-size: 1rem;
        color: var(--text-primary);
        line-height: 1.2;
      }

      .sidebar-brand .brand-sub {
        font-size: 0.7rem;
        color: var(--text-secondary);
      }

      .sidebar-nav { padding: 0.75rem 0; flex: 1; }

      .sidebar-nav .nav-section {
        padding: 0.5rem 1rem 0.25rem;
        font-size: 0.7rem;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.08em;
        color: var(--text-secondary);
      }

      .sidebar-nav a {
        display: flex;
        align-items: center;
        gap: 0.65rem;
        padding: 0.55rem 1rem;
        color: var(--text-secondary);
        text-decoration: none;
        border-left: 3px solid transparent;
        transition: all 0.15s;
        font-size: 0.875rem;
      }

      .sidebar-nav a:hover {
        color: var(--text-primary);
        background: rgba(255,255,255,0.05);
      }

      .sidebar-nav a.active {
        color: var(--accent-blue);
        border-left-color: var(--accent-blue);
        background: rgba(59,130,246,0.08);
        font-weight: 600;
      }

      .sidebar-footer {
        padding: 1rem;
        border-top: 1px solid var(--border-color);
        font-size: 0.7rem;
        color: var(--text-secondary);
      }

      /* -- Main content -- */
      .main-wrapper {
        margin-left: var(--sidebar-width);
        flex: 1;
        display: flex;
        flex-direction: column;
        min-height: 100vh;
      }

      .top-bar {
        background: var(--bg-secondary);
        border-bottom: 1px solid var(--border-color);
        padding: 0.75rem 1.5rem;
        display: flex;
        align-items: center;
        justify-content: space-between;
        position: sticky;
        top: 0;
        z-index: 50;
      }

      .top-bar .page-title {
        font-weight: 600;
        font-size: 1rem;
        color: var(--text-primary);
      }

      .top-bar .breadcrumb {
        font-size: 0.78rem;
        color: var(--text-secondary);
        margin: 0;
        background: none;
        padding: 0;
      }

      .top-bar .breadcrumb-item + .breadcrumb-item::before {
        color: var(--text-secondary);
      }

      .main-content {
        padding: 1.5rem;
        flex: 1;
      }

      /* -- Cards -- */
      .card-dark {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.25rem;
        transition: border-color 0.15s;
      }

      .card-dark:hover { border-color: #475569; }

      .stat-card {
        background: var(--bg-card);
        border: 1px solid var(--border-color);
        border-radius: 12px;
        padding: 1.25rem;
        display: flex;
        align-items: center;
        gap: 1rem;
      }

      .stat-card .stat-icon {
        width: 48px; height: 48px;
        border-radius: 10px;
        display: flex; align-items: center; justify-content: center;
        font-size: 1.4rem;
        flex-shrink: 0;
      }

      .stat-card .stat-value {
        font-size: 1.75rem;
        font-weight: 700;
        line-height: 1;
        color: var(--text-primary);
      }

      .stat-card .stat-label {
        font-size: 0.78rem;
        color: var(--text-secondary);
        margin-top: 0.2rem;
      }

      /* -- Badges -- */
      .badge-critical { background: #7f1d1d; color: #fca5a5; }
      .badge-high     { background: #7c2d12; color: #fdba74; }
      .badge-medium   { background: #713f12; color: #fde68a; }
      .badge-low      { background: #14532d; color: #86efac; }

      .severity-critical { border-left: 3px solid var(--accent-red) !important; }
      .severity-high     { border-left: 3px solid #f97316 !important; }
      .severity-medium   { border-left: 3px solid var(--accent-amber) !important; }
      .severity-low      { border-left: 3px solid var(--accent-green) !important; }

      /* -- Tables -- */
      .table-dark-custom {
        color: var(--text-primary);
        border-color: var(--border-color);
      }

      .table-dark-custom th {
        background: rgba(255,255,255,0.04);
        color: var(--text-secondary);
        font-weight: 500;
        font-size: 0.78rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        border-color: var(--border-color);
        padding: 0.6rem 0.75rem;
      }

      .table-dark-custom td {
        border-color: var(--border-color);
        vertical-align: middle;
        padding: 0.65rem 0.75rem;
        font-size: 0.85rem;
      }

      .table-dark-custom tbody tr:hover {
        background: rgba(255,255,255,0.03);
      }

      /* -- Forms -- */
      .form-control-dark, .form-select-dark {
        background: rgba(255,255,255,0.05);
        border: 1px solid var(--border-color);
        color: var(--text-primary);
        border-radius: 8px;
      }

      .form-control-dark:focus, .form-select-dark:focus {
        background: rgba(255,255,255,0.08);
        border-color: var(--accent-blue);
        color: var(--text-primary);
        box-shadow: 0 0 0 3px rgba(59,130,246,0.15);
        outline: none;
      }

      textarea.form-control-dark { font-family: 'JetBrains Mono', 'Fira Code', monospace; font-size: 0.8rem; }

      /* -- Log terminal -- */
      .log-terminal {
        background: #0a0f1a;
        border: 1px solid var(--border-color);
        border-radius: 8px;
        font-family: 'JetBrains Mono', 'Courier New', monospace;
        font-size: 0.78rem;
        padding: 1rem;
        height: 420px;
        overflow-y: auto;
        line-height: 1.6;
      }

      .log-normal  { color: #94a3b8; }
      .log-anomaly { color: #ef4444; font-weight: 500; }
      .log-warning { color: #f59e0b; }

      /* -- Buttons -- */
      .btn-primary-custom {
        background: var(--accent-blue);
        color: #fff;
        border: none;
        border-radius: 8px;
        padding: 0.5rem 1.25rem;
        font-weight: 500;
        transition: background 0.15s;
      }

      .btn-primary-custom:hover { background: #2563eb; color: #fff; }

      /* -- Animations -- */
      @keyframes pulse-red { 0%, 100% { opacity: 1; } 50% { opacity: 0.5; } }
      .anomaly-pulse { animation: pulse-red 2s infinite; }

      /* -- Alert notices -- */
      .flash-notice {
        background: rgba(34,197,94,0.1);
        border: 1px solid rgba(34,197,94,0.3);
        color: #86efac;
        border-radius: 8px;
        padding: 0.65rem 1rem;
        font-size: 0.85rem;
      }

      .flash-alert {
        background: rgba(239,68,68,0.1);
        border: 1px solid rgba(239,68,68,0.3);
        color: #fca5a5;
        border-radius: 8px;
        padding: 0.65rem 1rem;
        font-size: 0.85rem;
      }
    </style>
  </head>

  <body>
    <!-- Sidebar -->
    <nav class="sidebar">
      <div class="sidebar-brand">
        <div class="brand-icon"><i class="bi bi-activity text-white"></i></div>
        <div>
          <div class="brand-name">LogAnomalyML</div>
          <div class="brand-sub">BGL Anomaly Detection</div>
        </div>
      </div>

      <div class="sidebar-nav">
        <div class="nav-section">Main</div>
        <%= link_to dashboard_path, class: "#{controller_name == 'dashboard' ? 'active' : ''}" do %>
          <i class="bi bi-speedometer2"></i> Dashboard
        <% end %>

        <div class="nav-section mt-2">Analysis</div>
        <%= link_to analysis_path, class: "#{controller_name == 'analysis' ? 'active' : ''}" do %>
          <i class="bi bi-search"></i> Log Analysis
        <% end %>
        <%= link_to alerts_path, class: "#{controller_name == 'alerts' ? 'active' : ''}" do %>
          <i class="bi bi-bell-fill"></i> Anomaly Alerts
          <% new_count = AnomalyAlert.where(status: 'new').count rescue 0 %>
          <% if new_count > 0 %>
            <span class="ms-auto badge rounded-pill" style="background:var(--accent-red);font-size:0.65rem;"><%= new_count %></span>
          <% end %>
        <% end %>

        <div class="nav-section mt-2">Models</div>
        <%= link_to performance_path, class: "#{controller_name == 'performance' ? 'active' : ''}" do %>
          <i class="bi bi-bar-chart-line"></i> Model Performance
        <% end %>
        <%= link_to monitor_path, class: "#{controller_name == 'monitor' ? 'active' : ''}" do %>
          <i class="bi bi-broadcast"></i> Live Monitor
        <% end %>
      </div>

      <div class="sidebar-footer">
        <div><i class="bi bi-mortarboard me-1"></i> MSc AI Dissertation</div>
        <div class="mt-1" style="color:#64748b;">Subhan Jameel - U2926092</div>
        <div class="mt-1" style="color:#64748b;">University of East London</div>
      </div>
    </nav>

    <!-- Main wrapper -->
    <div class="main-wrapper">
      <!-- Top bar -->
      <div class="top-bar">
        <div>
          <div class="page-title"><%= content_for(:page_title) { controller_name.titleize } %></div>
          <nav aria-label="breadcrumb">
            <ol class="breadcrumb">
              <li class="breadcrumb-item"><a href="/" style="color:var(--accent-blue);text-decoration:none;">Home</a></li>
              <% if content_for?(:breadcrumb) %>
                <%= yield :breadcrumb %>
              <% else %>
                <li class="breadcrumb-item active"><%= controller_name.titleize %></li>
              <% end %>
            </ol>
          </nav>
        </div>
        <div class="d-flex align-items-center gap-3">
          <span style="font-size:0.75rem; color:var(--text-secondary);">
            <i class="bi bi-circle-fill me-1" style="color:var(--accent-green);font-size:0.5rem;"></i>
            BGL Dataset - Random Forest Active
          </span>
          <span style="font-size:0.75rem;color:var(--text-secondary);">
            <%= Time.current.strftime("%d %b %Y") %>
          </span>
        </div>
      </div>

      <!-- Flash messages -->
      <div class="main-content" style="padding-bottom:0;padding-top:0.75rem;">
        <% if flash[:notice].present? %>
          <div class="flash-notice mb-3"><i class="bi bi-check-circle me-2"></i><%= flash[:notice] %></div>
        <% end %>
        <% if flash[:alert].present? %>
          <div class="flash-alert mb-3"><i class="bi bi-exclamation-triangle me-2"></i><%= flash[:alert] %></div>
        <% end %>
      </div>

      <!-- Page content -->
      <div class="main-content pt-2">
        <%= yield %>
      </div>
    </div>

    <!-- Bootstrap JS -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js"></script>
  </body>
</html>
