<% content_for :page_title, "Dashboard" %>

<% if @metrics["warning"].present? %>
  <div class="flash-alert mb-3" style="font-size:0.82rem;"><i class="bi bi-info-circle me-2"></i><%= @metrics["warning"] %></div>
<% end %>
<% if @metrics["data_source"].present? %>
  <div class="mb-2" style="font-size:0.78rem;color:var(--text-secondary);">
    Training data: <strong style="color:var(--text-primary);"><%= @metrics["data_source"] %></strong>
    <% if @metrics["eval_split"].present? %> · eval split: <code style="font-size:0.72rem;"><%= @metrics["eval_split"] %></code><% end %>
    · <%= @metrics["test_samples"].to_i %> holdout windows
  </div>
<% end %>
<% if @metrics_source.present? && @metrics_source != "holdout_eval" %>
  <div class="mb-3" style="font-size:0.78rem;color:var(--text-secondary);">
    Metrics source: <code style="font-size:0.75rem;"><%= @metrics_source %></code>
    <% if @metrics_source == "training_metadata" %> — run ML training to generate <code style="font-size:0.75rem;">eval_holdout.npz</code> for live holdout scores.<% end %>
  </div>
<% end %>
<% if @metrics["metric_note"].present? %>
  <div class="mb-3 p-2 rounded" style="font-size:0.78rem;color:#fde68a;background:rgba(245,158,11,0.12);border:1px solid rgba(245,158,11,0.35);">
    <i class="bi bi-info-circle me-1"></i><%= @metrics["metric_note"] %>
  </div>
<% end %>

<!-- Stat Cards Row -->
<div class="row g-3 mb-4">
  <div class="col-md-3">
    <div class="stat-card">
      <div class="stat-icon" style="background:rgba(239,68,68,0.15);">
        <i class="bi bi-exclamation-triangle-fill" style="color:#ef4444;"></i>
      </div>
      <div>
        <div class="stat-value" id="dash-stat-today-alerts"><%= @today_alerts %></div>
        <div class="stat-label">Anomalies Today</div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="stat-card">
      <div class="stat-icon" style="background:rgba(59,130,246,0.15);">
        <i class="bi bi-file-text" style="color:#3b82f6;"></i>
      </div>
      <div>
        <div class="stat-value" id="dash-stat-log-lines"><%= @log_lines_today %></div>
        <div class="stat-label">Log lines analysed today</div>
        <div class="stat-hint" style="font-size:0.65rem;color:var(--text-secondary);margin-top:0.2rem;">Auto-refreshing every 15s</div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="stat-card">
      <div class="stat-icon" style="background:rgba(34,197,94,0.15);">
        <i class="bi bi-graph-up" style="color:#22c55e;"></i>
      </div>
      <div>
        <% f1h = @metrics["f1_score"] %>
        <div class="stat-value" id="dash-stat-f1" style="font-size:1.35rem;"><%= f1h.nil? ? "—" : ml_rate(f1h, precision: 3) %></div>
        <div class="stat-label">F1 score (holdout, 0–1)</div>
        <div class="stat-hint" style="font-size:0.65rem;color:var(--text-secondary);margin-top:0.2rem;"><%= f1h.nil? ? "BERT-Log" : ml_pct(f1h, precision: 2) %> · n=<%= @metrics["n_eval_samples"] || @metrics["test_samples"].to_i %></div>
      </div>
    </div>
  </div>
  <div class="col-md-3">
    <div class="stat-card">
      <div class="stat-icon" style="background:rgba(245,158,11,0.15);">
        <i class="bi bi-shield-check" style="color:#f59e0b;"></i>
      </div>
      <div>
        <div class="stat-value" id="dash-stat-fpr"><%= @metrics["false_positive_rate"].nil? ? "—" : ml_rate(@metrics["false_positive_rate"], precision: 3) %></div>
        <div class="stat-label">FPR (0–1, holdout)</div>
        <div class="stat-hint" style="font-size:0.65rem;color:var(--text-secondary);margin-top:0.2rem;">Auto-refreshing</div>
      </div>
    </div>
  </div>
</div>

<!-- Charts Row -->
<div class="row g-3 mb-4">
  <div class="col-md-8">
    <div class="card-dark h-100">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-activity me-2" style="color:#3b82f6;"></i>Anomaly Detections — Last 24 Hours</h6>
      </div>
      <canvas id="timelineChart" height="120"></canvas>
    </div>
  </div>
  <div class="col-md-4">
    <div class="card-dark h-100">
      <h6 class="mb-3 fw-semibold"><i class="bi bi-pie-chart-fill me-2" style="color:#a855f7;"></i>Alert Severity Distribution</h6>
      <canvas id="severityChart" height="200"></canvas>
    </div>
  </div>
</div>

<!-- Model comparison + Recent Alerts -->
<div class="row g-3 mb-4">
  <div class="col-md-5">
    <div class="card-dark">
      <h6 class="mb-3 fw-semibold"><i class="bi bi-bar-chart-fill me-2" style="color:#22c55e;"></i>Model F1-Score Comparison</h6>
      <canvas id="modelCompareChart" height="220"></canvas>
    </div>
  </div>
  <div class="col-md-7">
    <div class="card-dark">
      <div class="d-flex justify-content-between align-items-center mb-3">
        <h6 class="mb-0 fw-semibold"><i class="bi bi-bell-fill me-2" style="color:#ef4444;"></i>Recent Anomaly Alerts</h6>
        <%= link_to "View All →", alerts_path, style: "font-size:0.78rem;color:#3b82f6;text-decoration:none;" %>
      </div>
      <% if @recent_alerts.any? %>
        <table class="table table-dark-custom mb-0">
          <thead><tr><th>Severity</th><th>Score</th><th>Model</th><th>Status</th><th>Time</th></tr></thead>
          <tbody>
            <% @recent_alerts.each do |alert| %>
              <tr>
                <td><span class="badge badge-<%= alert.severity || 'low' %> rounded-pill px-2 py-1"><%= (alert.severity || "low").capitalize %></span></td>
                <td>
                  <div class="d-flex align-items-center gap-2">
                    <div class="progress" style="height:5px;background:#334155;width:50px;">
                      <div class="progress-bar" style="width:<%= (alert.anomaly_score.to_f*100).round %>%;background:#ef4444;"></div>
                    </div>
                    <small><%= alert.anomaly_score.to_f.round(3) %></small>
                  </div>
                </td>
                <td><small style="color:var(--text-secondary);"><%= alert.alert_model_name || "BERT-Log" %></small></td>
                <td>
                  <span class="badge rounded-pill" style="background:rgba(59,130,246,0.15);color:#93c5fd;font-size:0.7rem;">
                    <%= (alert.status || "new").capitalize %>
                  </span>
                </td>
                <td><small style="color:var(--text-secondary);"><%= alert.detected_at ? time_ago_in_words(alert.detected_at) + " ago" : "—" %></small></td>
              </tr>
            <% end %>
          </tbody>
        </table>
      <% else %>
        <div class="text-center py-5" style="color:var(--text-secondary);">
          <i class="bi bi-check-circle-fill mb-2" style="font-size:2rem;color:#22c55e;display:block;"></i>
          No alerts yet. <%= link_to "Analyse logs", analysis_path, style: "color:#3b82f6;" %> to get started.
        </div>
      <% end %>
    </div>
  </div>
</div>

<!-- System Overview -->
<div class="card-dark">
  <h6 class="mb-3 fw-semibold"><i class="bi bi-info-circle me-2" style="color:#3b82f6;"></i>System Overview — BGL Dataset</h6>
  <div class="row text-center g-3">
    <% stats = [
         [@metrics["test_samples"].to_i.positive? ? number_with_delimiter(@metrics["test_samples"].to_i) : "—","Holdout test windows","#3b82f6"],
         [@metrics["training_samples"].to_i.positive? ? number_with_delimiter(@metrics["training_samples"].to_i) : "—","Training windows","#64748b"],
         ["<span id=\"dash-stat-auc\">#{ml_rate(@metrics['auc_roc'], precision: 3)}</span>","AUC-ROC (0–1, holdout)","#22c55e"],
         ["#{@metrics['detection_latency_ms']&.to_f&.round(3) || "—"}ms","Latency / window (est.)","#f59e0b"],
         ["Drain","Log Parser","#a855f7"],["SHAP","Explainability","#06b6d4"]] %>
    <% stats.each do |val, label, color| %>
      <div class="col">
        <div style="font-size:1.4rem;font-weight:700;color:<%= color %>;"><%= raw val %></div>
        <div style="font-size:0.75rem;color:var(--text-secondary);margin-top:0.2rem;"><%= label %></div>
      </div>
    <% end %>
  </div>
</div>

<script>
const models = <%= raw @models.to_json %>;

const dashTimelineChart = new Chart(document.getElementById('timelineChart'), {
  type: 'line',
  data: {
    labels: <%= raw @hourly_labels.to_json %>,
    datasets: [{
      label: 'Anomalies', data: <%= raw @hourly_counts.to_json %>,
      borderColor: '#ef4444', backgroundColor: 'rgba(239,68,68,0.08)',
      fill: true, tension: 0.4, pointRadius: 2,
    }]
  },
  options: { responsive: true, plugins: { legend: { display: false } },
    scales: { x: { ticks: { color: '#64748b', font: { size: 9 }, maxTicksLimit: 8 }, grid: { color: 'rgba(255,255,255,0.04)' } },
               y: { ticks: { color: '#64748b' }, grid: { color: 'rgba(255,255,255,0.04)' } } } }
});

const dashSeverityChart = new Chart(document.getElementById('severityChart'), {
  type: 'doughnut',
  data: {
    labels: ['Critical','High','Medium','Low'],
    datasets: [{ data: [<%= @severity_counts['critical'] %>,<%= @severity_counts['high'] %>,<%= @severity_counts['medium'] %>,<%= @severity_counts['low'] %>],
      backgroundColor: ['#ef4444','#f97316','#f59e0b','#22c55e'], borderWidth: 0 }]
  },
  options: { responsive: true, cutout: '65%',
    plugins: { legend: { position: 'bottom', labels: { color: '#94a3b8', font: { size: 10 } } } } }
});

const dashModelChart = new Chart(document.getElementById('modelCompareChart'), {
  type: 'bar',
  data: {
    labels: models.map(m => m.name.replace(' ', '\n')),
    datasets: [
      { label: 'F1',        data: models.map(m => m.f1_score),  backgroundColor: '#3b82f6' },
      { label: 'Precision', data: models.map(m => m.precision), backgroundColor: '#22c55e' },
      { label: 'Recall',    data: models.map(m => m.recall),    backgroundColor: '#a855f7' },
    ]
  },
  options: {
    responsive: true,
    scales: { x: { ticks: { color: '#64748b', font: { size: 9 } }, grid: { color: 'rgba(255,255,255,0.04)' } },
               y: { min: 0, max: 1, ticks: { color: '#64748b', font: { size: 10 } }, grid: { color: 'rgba(255,255,255,0.04)' } } },
    plugins: { legend: { labels: { color: '#94a3b8', font: { size: 10 } } } }
  }
});

(function dashboardPoll() {
  const path = "/dashboard/snapshot";
  async function tick() {
    try {
      const r = await fetch(path, { headers: { 'Accept': 'application/json', 'X-Requested-With': 'XMLHttpRequest' } });
      if (!r.ok) return;
      const j = await r.json();
      const el = (id) => document.getElementById(id);
      if (j.today_alerts != null) el('dash-stat-today-alerts') && (el('dash-stat-today-alerts').textContent = j.today_alerts);
      if (j.log_lines_today != null) el('dash-stat-log-lines') && (el('dash-stat-log-lines').textContent = j.log_lines_today);
      const m = j.metrics || {};
      const r3 = (x) => (Number(x)).toFixed(3);
      if (m.f1_score != null) el('dash-stat-f1') && (el('dash-stat-f1').textContent = r3(m.f1_score));
      if (m.false_positive_rate != null) el('dash-stat-fpr') && (el('dash-stat-fpr').textContent = r3(m.false_positive_rate));
      const aucEl = document.getElementById('dash-stat-auc');
      if (aucEl && m.auc_roc != null) aucEl.textContent = r3(m.auc_roc);
      if (j.hourly_counts && dashTimelineChart) {
        dashTimelineChart.data.datasets[0].data = j.hourly_counts;
        dashTimelineChart.update('none');
      }
      if (j.severity && dashSeverityChart) {
        const s = j.severity;
        dashSeverityChart.data.datasets[0].data = [s.critical, s.high, s.medium, s.low];
        dashSeverityChart.update('none');
      }
      if (j.models && j.models[0] && dashModelChart) {
        const mm = j.models[0];
        dashModelChart.data.datasets[0].data = [mm.f1_score];
        dashModelChart.data.datasets[1].data = [mm.precision];
        dashModelChart.data.datasets[2].data = [mm.recall];
        dashModelChart.update('none');
      }
    } catch (e) { /* offline */ }
  }
  setInterval(tick, 15000);
})();
</script>
